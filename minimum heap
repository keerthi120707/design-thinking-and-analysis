class MinHeap:
    def __init__(self):
        self.heap = []

    def parent(self, i):
        return (i - 1) // 2

    def left_child(self, i):
        return 2 * i + 1

    def right_child(self, i):
        return 2 * i + 2

    def swap(self, i, j):
        self.heap[i], self.heap[j] = self.heap[j], self.heap[i]

    def insert(self, key):
        """Adds a new key to the heap and restores heap property."""
        self.heap.append(key)
        self.heapify_up(len(self.heap) - 1)

    def extract_min(self):
        """Removes and returns the smallest element."""
        if len(self.heap) == 0:
            return None
        if len(self.heap) == 1:
            return self.heap.pop()

        root = self.heap[0]
        self.heap[0] = self.heap.pop()
        self.heapify_down(0)
        return root

    def heapify_up(self, i):
        """Fixes the heap property by moving node up."""
        while i > 0 and self.heap[self.parent(i)] > self.heap[i]:
            self.swap(i, self.parent(i))
            i = self.parent(i)

    def heapify_down(self, i):
        """Fixes the heap property by moving node down."""
        min_index = i
        left = self.left_child(i)
        right = self.right_child(i)

        if left < len(self.heap) and self.heap[left] < self.heap[min_index]:
            min_index = left
        if right < len(self.heap) and self.heap[right] < self.heap[min_index]:
            min_index = right

        if i != min_index:
            self.swap(i, min_index)
            self.heapify_down(min_index)

# Usage Example
min_heap = MinHeap()
min_heap.insert(10)
min_heap.insert(5)
min_heap.insert(15)
min_heap.insert(2)
print(min_heap.extract_min())  # Output: 2
print(min_heap.extract_min())  # Output: 5
